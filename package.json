{
  "name": "fundamentals-project-ts-template",
  "version": "1.0.0",
  "description": "Capstone Project TS Template",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "sass src/scss:dist/css && tsc && cpx src/index.html dist/ && cpx src/img dist/img",
    "ts-compile": "npx tsc",
    "compile": "sass src/scss:dist/css",
    "dev": "sass --watch src/scss:dist/css",
    "ts-dev": "npx tsc -w",
    "lint": "eslint src --ext .ts && stylelint \"src/**/*.scss\""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [],
  "author": "Andrea Kozar",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "cpx": "^1.5.0",
    "eslint": "^10.3.0",
    "sass": "^1.99.0",
    "stylelint": "^17.9.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1"
  }
}
